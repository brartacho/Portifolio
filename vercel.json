{
  "crons": [
    {
      "path": "/api/track",
      "schedule": "0 8 */4 * *"
    },
    {
      "path": "/api/demo/cleanup",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/admin/analytics",       "destination": "/api/admin/applications?__h=analytics" },
    { "source": "/api/admin/login-attempts",   "destination": "/api/admin/applications?__h=login-attempts" },
    { "source": "/api/admin/mark-my-visits",   "destination": "/api/admin/applications?__h=mark-my-visits" },
    { "source": "/api/admin/storage-stats",    "destination": "/api/admin/applications?__h=storage-stats" },
    { "source": "/api/admin/visitor-journey",  "destination": "/api/admin/applications?__h=visitor-journey" },
    { "source": "/api/admin/log-share", "destination": "/api/admin/logs?__h=share" },
    { "source": "/api/demo/config",        "destination": "/api/demo?resource=config" },
    { "source": "/api/demo/init",          "destination": "/api/demo?resource=init" },
    { "source": "/api/demo/cleanup",       "destination": "/api/demo?resource=cleanup" },
    { "source": "/api/demo/health",        "destination": "/api/demo?resource=health" },
    { "source": "/api/demo/analytics",     "destination": "/api/demo?resource=analytics" },
    { "source": "/api/demo/applications",  "destination": "/api/demo?resource=applications" },
    { "source": "/api/demo/cv-versions",   "destination": "/api/demo?resource=cv-versions" },
    { "source": "/api/demo/tokens",        "destination": "/api/demo?resource=tokens" },
    { "source": "/api/demo/logs",          "destination": "/api/demo?resource=logs" },
    { "source": "/api/demo/storage-stats", "destination": "/api/demo?resource=storage-stats" },
    { "source": "/api/cv/download",         "destination": "/api/cv?action=download" },
    { "source": "/api/cv/request-by-email", "destination": "/api/cv?action=request-by-email" },
    { "source": "/cv",          "destination": "/cv.html" },
    { "source": "/admin",       "destination": "/admin/index.html" },
    { "source": "/admin/reset", "destination": "/admin/reset.html" },
    { "source": "/privacidade", "destination": "/privacidade.html" },
    { "source": "/projeto-sistema-admin", "destination": "/projeto-sistema-admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/admin/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/admin/service-worker.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Service-Worker-Allowed", "value": "/admin/" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
