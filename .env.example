# ─── SUPABASE ────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nome do bucket privado no Storage (default: curriculos)
SUPABASE_BUCKET=curriculos

# ─── AUTH ADMIN ──────────────────────────────────────────────
# Identidade do admin (qualquer um dos dois funciona no login).
# Se ADMIN_EMAIL não for setado, o login aceita o NOTIFY_EMAIL.
ADMIN_EMAIL=bruno@artacho.dev
ADMIN_PHONE=5544984366533

# Hash bcrypt da senha do painel admin.
# Gerar com: node scripts/gen-password-hash.mjs SUA_SENHA
ADMIN_PASSWORD_HASH=$2b$12$...

# Secret para assinar os JWTs de sessão admin (string aleatória longa)
# Gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ─── BASE URLs ───────────────────────────────────────────────
# Onde o admin roda (usado em links de reset de senha)
NEXT_PUBLIC_BASE_URL=https://artacho.dev

# URL pública pra onde os recrutadores são direcionados (link de download).
# Em DEV, deixe apontando pra produção pra que os links sejam clicáveis em apps
# (WhatsApp/Telegram só linkam URLs HTTPS com TLD válido — localhost não funciona).
PUBLIC_SHARE_URL=https://artacho.dev

# ─── NOTIFICAÇÕES (opcionais) ────────────────────────────────
# Telegram — cria um bot em @BotFather e adicione ao seu canal/grupo
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend — https://resend.com (plano free: 3000 emails/mês)
RESEND_API_KEY=
NOTIFY_EMAIL=bruno@artacho.dev
